{
  "expo": {
    "name": "BexieMart",
    "slug": "bexiemart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bexiemart",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bexiemart.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of products to sell on BexieMart.",
        "NSPhotoLibraryUsageDescription": "Select product images from your photo library.",
        "NSLocationWhenInUseUsageDescription": "BexieMart needs your location to track deliveries and riders."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#004CFF"
      },
      "package": "com.bexiemart.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#004CFF",
          "image": "./assets/images/icon.png",
          "imageWidth": 200

        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Select product images for your BexieMart listings.",
          "cameraPermission": "Take photos of your products for BexieMart."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableEdgeToEdge": true,
            "newArchEnabled": true
          },
          "ios": {
            "useFrameworks": "static",
            "newArchEnabled": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a830e794-6932-47fd-9779-9b1317c59f3f"
      }
    }
  }
}